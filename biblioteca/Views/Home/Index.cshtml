@{
    ViewData["Title"] = "Home Page";
    var totalLivros = (int)ViewData["TotalLivros"];
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

<div class="container mt-5">
    <h1 class="mb-4 text-center display-4">Dashboard</h1>

    <div class="row g-4 justify-content-center">

        <!-- Total Livros -->
        <div class="col-sm-6 col-md-4 col-lg-3">
            <div class="card text-white bg-primary shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-book-fill fs-1 me-3"></i>
                    <div>
                        <h5 class="card-title">Total Livros</h5>
                        <h2 class="card-text">@totalLivros</h2>
                    </div>
                </div>
                <div class="card-footer text-end bg-primary">
                    <a class="text-white text-decoration-none" asp-controller="Book" asp-action="Index">
                        Ver Livros <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Exemplo: Total Autores -->
        <div class="col-sm-6 col-md-4 col-lg-3">
            <div class="card text-white bg-success shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-person-badge-fill fs-1 me-3"></i>
                    <div>
                        <h5 class="card-title">Total Autores</h5>
                        <h2 class="card-text">5</h2>
                    </div>
                </div>
                <div class="card-footer text-end bg-success">
                    <a class="text-white text-decoration-none" asp-controller="Book" asp-action="Index">
                        Ver Autores <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Exemplo: Total Categorias -->
        <div class="col-sm-6 col-md-4 col-lg-3">
            <div class="card text-white bg-warning shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-tags-fill fs-1 me-3"></i>
                    <div>
                        <h5 class="card-title">Total Categorias</h5>
                        <h2 class="card-text">3</h2>
                    </div>
                </div>
                <div class="card-footer text-end bg-warning">
                    <a class="text-dark text-decoration-none" asp-controller="Categoria" asp-action="Index">
                        Ver Categorias <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>