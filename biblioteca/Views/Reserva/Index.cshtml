@using biblioteca.Models
@model Reserva

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}


<div class="row">
    <label>
        Nome Utilizador:
    </label>
    <p>@Model.User.Nome</p>

    <label>
        Nif :
    </label>
    <p>@Model.User.Nif</p>

    <label>
        Tempo Total:
    </label>
    <p>@Model.TempoDias</p>

    <label>
        Custo un:
    </label>
    <p>@Model.CustoUn</p>
    <label>
        Custo total:
    </label>
    <p>@Model.CustoTotal</p>
    <label>
        Livros:
    </label>
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Título</th>
                <th>Autor</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in Model.Livro)
            {
                <tr>
                    <td>@book.Title</td>
                    <td>@book.Autor</td>
                </tr>
            }
        </tbody>
    </table>
</div>