@model biblioteca.Models.Book

@{
    List<Categoria> categorias = (List<Categoria>)ViewBag.Categorias;
}

<div class="container mt-4">
    <h2>Adicionar Novo Livro</h2>

    <form asp-action="Create" method="post" class="mt-3">
        <div class="mb-3">
            <label class="form-label">Título</label>
            <input asp-for="Title" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Autor</label>
            <input asp-for="Autor" class="form-control" />
        </div>
        @*         <div class="mb-3">
            <label class="form-label">Categoria</label>
            <input asp-for="CategoriaId" class="form-control" />
        </div> *@
        <select class="form-select" asp-for="CategoriaId">
            <option selected>Selecione uma Categoria</option>
            @foreach (var cat in categorias)
            {
                <option value="@cat.Id">@cat.Nome</option>
            }

        </select>
        <div class="mb-3">
            <label class="form-label">Quantidade</label>
            <input asp-for="Quantidade" type="number" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
    </form>
</div>