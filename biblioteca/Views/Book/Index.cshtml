@model List<Book>

@{
    ViewData["Title"] = "Lista de Livros";


    List<Categoria> categorias = (List<Categoria>)ViewBag.Categorias;


}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<div class="card">
    <div class="card-body">

        <form>
            <div class="col-6">
                <select class="form-select" name="categoria">
                    <option selected>Selecione uma Categoria</option>
                    @foreach (var cat in categorias)
                    {
                        <option value="@cat.Id">@cat.Nome</option>
                    }

                </select>
            </div>
            <div class="col-6">
                <button type="submit" class="btn btn-primary btn-xs">Fitlrar</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center">
        Listagem de livros
        <a class="btn btn-primary btn-sm ms-auto" asp-area="" asp-controller="Book" asp-action="New">
            <i class="bi bi-plus me-1"></i> Add Book
        </a>
    </div>
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Título</th>
                    <th>Autor</th>
                    <th>Categoria</th>
                    <th>Quantidade</th>
                    <th>Criado</th>
                    <th>Actualizado</th>
                    <th>#</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var book in Model)
                {
                    <tr>
                        <td>@book.Title</td>
                        <td>@book.Autor</td>
                        <td>@book.CategoriaId - @book.Categoria.Nome</td>
                        <td>@book.Quantidade</td>
                        <td>@book.CreateAt.ToString("dd/MM/yyyy")</td>
                        <td>@book.UpdateAt.ToString("dd/MM/yyyy")</td>
                        <td>
                            <a class="btn btn-sm btn-warning" asp-controller="Book" asp-action="Edit" asp-route-id="@book.Id">
                                <i class="bi bi-pencil-square me-1"></i> Edit
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>




